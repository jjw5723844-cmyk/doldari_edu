<div class="login-container">
    <div class="login-box">
        <div class="login-header">
            <h2>비밀번호 찾기</h2>
            <p>가입 시 등록한 아이디와 이메일을 입력해 주세요.</p>
        </div>

        <form action="/find_pw" method="post" class="login-form">
            <div class="input-group">
                <label for="username">아이디</label>
                <input type="text" id="username" name="username" placeholder="아이디를 입력사세요." required>
            </div>

            <div class="input-group">
                <label for="email">이메일 주소</label>
                <input type="email" id="email" name="email" placeholder="example@email.com" required>
            </div>

            <button type="submit" class="login-btn">임시 비밀번호 발송</button>
        </form>

        <div class="login-footer">
            <a href="/login">로그인으로 돌아가기</a>
            <span class="divider">|</span>
            <a href="/find_id">아이디 찾기</a>
        </div>
    </div>
</div>
