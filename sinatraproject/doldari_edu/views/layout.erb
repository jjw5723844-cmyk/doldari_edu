<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>함께 걷는 돌다리 학습</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/style_2.css">
</head>

<body>
<header>
    <!-- 상단 미니 메뉴 구성(로그인, 회원가입, 사이트맵 등) -->
    <div class="top-bar">
        <div class="container">
            <div class="util-menu">
                <a href="/login">로그인</a>
                <span class="divider">|</span>
                <a href="/join">회원가입</a>
                <span class="divider">|</span>
                <a href="/sitemap">사이트맵</a>
            </div>
        </div>
    </div>

    <!-- 메인 네비게이션 영역 -->
    <nav>
        <h1><a href="/">돌다리 학습</a></h1>

        <ul class="main-menu">
            <li><a href="/about">기관소개</a></li>
            <li><a href="/course">강의 신청</a></li>
            <li><a href="/notice">알림마당</a></li>
            <li><a href="/community">참여마당</a></li>
            <li><a href="/information">정보공개</a></li>
        </ul>

        <div class="search-box">
            <form action="/search" method="get" class="search-form">
                <input type="text" name="query" placeholder="강의명 또는 키워드 입력" class="search-input">
                <button type="submit" class="search-btn">검색</button>
            </form>
        </div>
    </nav>
</header>

    <main>
        <h2 style="color: var(--secondary-color); border-bottom: 2px solid var(--primary-color); padding-bottom: 10px;"></h2>
    <%= yield %>
    </main>
    
    <footer>
        <p>
            <a href="/sitemap" class="footer-link">사이트맵</a>
            <span class="footer-divider">|</span>
            @ 2026 돌다리 학습 평생교육원
        </p></footer>
</body>
</html>