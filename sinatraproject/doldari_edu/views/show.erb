<!-- views/show.erb -->
<div class="course-detail-header">
    <div class="category-badge"><%= @course[:category] %></div>
    <h2><%= @course[:name] %></h2>
</div>

<div class="course-detail-container">
    <!-- 주요 정보 요약 카드 -->
    <div class="info-summary-card">
        <table class="info-table">
            <tr>
                <th>수강 대상</th>
                <td><%= @course[:target] %></td>
            </tr>
            <tr>
                <th>강의 시간</th>
                <td><%= @course[:schedule] %></td>
            </tr>
            <tr>
                <th>수강료</th>
                <td class="fee-text">무료 (문의 바람)</td>
            </tr>
            <tr>
                <th>강의 장소</th>
                <td>돌다리 학습 본관 전용 강의실</td>
            </tr>
        </table>
        
        <div class="action-buttons">
            <button class="apply-btn" onclick="alert('신청 접수 기능은 준비 중입니다.')">온라인 수강 신청</button>
            <button class="wishlist-btn">⭐ 관심 강좌 등록</button>
        </div>
    </div>

    <!-- 상세 설명 영역 -->
    <div class="detail-content">
        <section class="desc-section">
            <h3>강좌 소개</h3>
            <div class="desc-box">
                <%= @course[:description] %>
            </div>
        </section>

        <section class="notice-section">
            <h3>수강 안내 사항</h3>
            <ul class="guide-list">
                <li>본 강의는 정원 미달 시 폐강될 수 있습니다.</li>
                <li>필기구 및 개인 준비물은 첫 수업 시 안내해 드립니다.</li>
                <li>수강 취소는 개강 3일 전까지 고객센터를 통해 가능합니다.</li>
            </ul>
        </section>
    </div>
</div>