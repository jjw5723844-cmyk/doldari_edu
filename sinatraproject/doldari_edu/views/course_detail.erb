<div class="detail-container">
    <div class="detail-header">
        <span class="category-tag"><%= @course[:category] %></span>
        <h2><%= @course[:name] %></h2>
    </div>

    <div class="detail-content">
        <section class="info-section">
            <h3>강의 소개</h3>
            <%= @course[:description] %>
        </section>

        <section class="info-grid">
            <div class="info-item">
                <strong>대상</strong>
                <span><%= @course[:target] %></span>
            </div>
            <div class="info-item">
                <strong>시간</strong>
                <span><%= @course[:schedule] %></span>
            </div>
        </section>

        <div class="action-area">
            <form action="/apply" method="POST">
                <input type="hidden" name="course_name" value="<%= @course[:name] %>">
                <button type="submit" class="apply-btn">지금 바로 수강신청하기</button>
            </form>
            <a href="javascript:history.back()" class="back-link">이전 페이지로</a>
        </div>
    </div>
</div>

<style>
    .detail-container { background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .detail-header { border-bottom: 2px solid var(--primary-color); padding-bottom: 20px; margin-bottom: 30px; }
    .detail-header h2 { font-size: 2.2rem; color: var(--secondary-color); margin-top: 10px; }

    .info-section h3 { color: var(--primary-color); margin-bottom: 15px; }
    .info-section p { font-size: 1.1rem; line-height: 1.8; color: #555; }

    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 30px 0; background: #f9f9f9; padding: 20px; border-radius: 10px; }
    .info-item strong { display: block; color: var(--secondary-color); margin-bottom: 5px; }

    .apply-btn { width: 100%; padding: 20px; font-size: 1.2rem; margin-bottom: 20px; }
    .back-link { display: block; text-align: center; color: #888; text-decoration: none; }
</style>
